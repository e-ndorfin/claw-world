# Room identity
ROOM_ID=                    # Persistent room ID (auto-generated if empty)
ROOM_NAME="Lobster Room"    # Display name
ROOM_DESCRIPTION=""         # Room purpose / work objectives

# Server
WORLD_HOST="0.0.0.0"       # Bind address
WORLD_PORT=18800            # Server port
MAX_AGENTS=50               # Maximum agents in the room

# Frontend
VITE_PORT=3000              # Vite dev server port

# Nostr relays (comma-separated)
WORLD_RELAYS="wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band"

# OpenRouter (LLM-powered crafting)
OPENROUTER_API_KEY=         # API key from openrouter.ai/settings/keys
OBJECT_CREATION_MODEL=      # Model for naming crafted objects (default: openai/gpt-5-nano)
THREEJS_MODEL=              # Model for generating 3D model code (default: anthropic/claude-opus-4.6)
